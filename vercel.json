{
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://popupserver.onrender.com/api/:match*"
    },
    {
      "source": "/uploads/:match*",
      "destination": "https://popupserver.onrender.com/uploads/:match*"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/admin.html",
      "destination": "/admin.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
